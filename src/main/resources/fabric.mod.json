{
	"schemaVersion": 1,
	"id": "tipped_sword",
	"version": "${version}",
	"name": "Tipped Swords",
	"description": "Coat your sword with potions, Wind Charges, or Fire Charges - fill vials from brewed potions, tip a sword with up to three, and land the effect on every hit.",
	"authors": [
		"SuplexGod"
	],
	"license": "MIT",
	"icon": "assets/tipped_sword/icon.png",
	"environment": "*",
	"entrypoints": {
		"main": [
			"com.cobblestoner.TippedSwords"
		],
		"client": [
			"com.cobblestoner.client.TippedSwordsClient"
		]
	},
	"mixins": [
		"tipped_swords.mixins.json",
		{
			"config": "tipped_swords.client.mixins.json",
			"environment": "client"
		}
	],
	"depends": {
		"fabricloader": ">=0.18.2",
		"minecraft": "~1.21.11",
		"java": ">=25",
		"fabric-api": "*"
	}
}
